                    "widgetTitle": "\u4e0a\u6d77\u822a\u4ea4\u6240\uff1a\u672c\u5468\u51fa\u53e3\u96c6\u88c5\u7bb1\u8fd0\u8f93\u5e02\u573a\u51fa\u73b0\u8c03\u6574 \u8fdc\u6d0b\u822a\u7ebf\u8fd0\u4ef7\u4e0b\u8dcc",
                    "widgetContent": "\u636e\u4e0a\u6d77\u822a\u8fd0\u4ea4\u6613\u6240\uff0c\u672c\u5468\uff0c\u4e2d\u56fd\u51fa\u53e3\u96c6\u88c5\u7bb1\u8fd0\u8f93\u5e02\u573a\u51fa\u73b0\u8c03\u6574\u884c\u60c5\uff0c\u8fdc\u6d0b\u822a\u7ebf\u8fd0\u4ef7\u8d70\u4f4e\uff0c\u62d6\u7d2f\u7efc\u5408\u6307\u6570\u4e0b\u8dcc\u30021\u670810\u65e5\uff0c\u4e0a\u6d77\u822a\u8fd0\u4ea4\u6613\u6240\u53d1\u5e03\u7684\u4e0a\u6d77\u51fa\u53e3\u96c6\u88c5\u7bb1\u7efc\u5408\u8fd0\u4ef7\u6307\u6570\u4e3a2290.68\u70b9\uff0c\u8f83\u4e0a\u671f\u4e0b\u8dcc8.6%\u3002\uff08\u8d22\u8054\u793e\uff09",
