                    "widgetTitle": "\u9ed1\u9f99\u6c5f\u7701\u65b0\u53d1\u5e0311\u9879\u51b0\u96ea\u7ecf\u6d4e\u9886\u57df\u5730\u65b9\u6807\u51c6",
                    "widgetContent": "\u5728\u7b2c41\u5c4a\u4e2d\u56fd\u00b7\u54c8\u5c14\u6ee8\u56fd\u9645\u51b0\u96ea\u8282\u542f\u5e55\u548c\u7b2c\u4e5d\u5c4a\u4e9a\u6d32\u51ac\u5b63\u8fd0\u52a8\u4f1a\u5373\u5c06\u53ec\u5f00\u4e4b\u9645\uff0c\u9ed1\u9f99\u6c5f\u7701\u5e02\u573a\u76d1\u7ba1\u5c40\u534f\u540c\u6587\u65c5\u3001\u4f53\u80b2\u7b49\u6709\u5173\u884c\u653f\u4e3b\u7ba1\u90e8\u95e8\u5236\u5b9a\u5e76\u6279\u51c6\u53d1\u5e0311\u9879\u51b0\u96ea\u7ecf\u6d4e\u9886\u57df\u5730\u65b9\u6807\u51c6\uff0c\u5206\u522b\u9488\u5bf9\u6ed1\u96ea\u573a\u7684\u5b89\u5168\u7ba1\u7406\u3001\u573a\u5730\u670d\u52a1\u8d28\u91cf\u3001\u9ed1\u9f99\u6c5f\u7701\u51b0\u96ea\u65c5\u6e38\u76ee\u7684\u5730\u5efa\u8bbe\u3001\u65c5\u6e38\u54c1\u724c\u521b\u5efa\u3001\u51b0\u96ea\u88c5\u5907\u5236\u9020\u7b49\u7ed9\u51fa\u660e\u786e\u8981\u6c42\u3001\u5efa\u8bae\u4e0e\u6307\u5f15\u3002",
