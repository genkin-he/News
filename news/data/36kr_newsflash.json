                    "widgetTitle": "54\u5bb6\u516c\u53f82024\u5e74\u4e1a\u7ee9\u9884\u589e",
                    "widgetContent": "\u622a\u81f31\u670811\u65e5\uff0c\u5df2\u7ecf\u670985\u5bb6\u516c\u53f8\u516c\u5e03\u4e862024\u5e74\u5ea6\u4e1a\u7ee9\u9884\u544a\u3002\u4e1a\u7ee9\u9884\u544a\u7c7b\u578b\u663e\u793a\uff0c\u9884\u589e\u516c\u53f854\u5bb6\u3001\u9884\u76c85\u5bb6\uff0c\u5408\u8ba1\u62a5\u559c\u516c\u53f8\u6bd4\u4f8b\u4e3a69.41%\uff1b\u4e1a\u7ee9\u9884\u964d\u3001\u9884\u4e8f\u516c\u53f8\u5206\u522b\u670917\u5bb6\u30015\u5bb6\u3002\n\n\u4e1a\u7ee9\u9884\u559c\u516c\u53f8\u4e2d\uff0c\u4ee5\u9884\u8ba1\u51c0\u5229\u6da6\u589e\u5e45\u4e2d\u503c\u7edf\u8ba1\uff0c\u5171\u670913\u5bb6\u516c\u53f8\u51c0\u5229\u6da6\u589e\u5e45\u8d85100%\uff1b\u51c0\u5229\u6da6\u589e\u5e45\u572850%~100%\u4e4b\u95f4\u7684\u670913\u5bb6\u3002\u5177\u4f53\u5230\u4e2a\u80a1\u770b\uff0c\u897f\u5b50\u6d01\u80fd\u9884\u8ba1\u51c0\u5229\u6da6\u589e\u5e45\u6700\u9ad8\u3002\u516c\u53f8\u9884\u8ba1\u5168\u5e74\u5b9e\u73b0\u51c0\u5229\u6da6\u589e\u5e45\u4e2d\u503c\u4e3a724.50%\uff1b\u5927\u535a\u533b\u7597\u3001\u7267\u539f\u80a1\u4efd\u9884\u8ba1\u5168\u5e74\u51c0\u5229\u6da6\u540c\u6bd4\u589e\u5e45\u4e2d\u503c\u5206\u522b\u4e3a527.42%\u3001510.48%\uff0c\u589e\u5e45\u4f4d\u5217\u7b2c\u4e8c\u3001\u7b2c\u4e09\u3002\uff08\u8bc1\u5238\u65f6\u62a5\uff09",
