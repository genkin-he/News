                    "widgetTitle": "2024\u5e74\u56db\u5b63\u5ea6\u6211\u56fd\u4e2d\u5c0f\u4f01\u4e1a\u53d1\u5c55\u6307\u6570\u4e0a\u53470.1\u70b9",
                    "widgetContent": "\u4e2d\u56fd\u4e2d\u5c0f\u4f01\u4e1a\u534f\u4f1a\u4eca\u5929\uff0812\u65e5\uff09\u53d1\u5e03\uff0c2024\u5e74\u56db\u5b63\u5ea6\uff0c\u4e2d\u56fd\u4e2d\u5c0f\u4f01\u4e1a\u53d1\u5c55\u6307\u6570\u4e3a89.0\uff0c\u76f8\u6bd4\u4e09\u5b63\u5ea6\u4e0a\u53470.1\u70b9\u3002\u56db\u5b63\u5ea6\uff0c\u53cd\u6620\u4f01\u4e1a\u603b\u4f53\u7ecf\u8425\u72b6\u51b5\u7684\u7efc\u5408\u7ecf\u8425\u6307\u6570\u3001\u53cd\u6620\u4f01\u4e1a\u8ba2\u5355\u3001\u751f\u4ea7\u3001\u9500\u552e\u4ee5\u53ca\u5e93\u5b58\u7b49\u65b9\u9762\u4f9b\u9700\u72b6\u51b5\u7684\u5e02\u573a\u6307\u6570\u5747\u6bd4\u4e09\u5b63\u5ea6\u4e0a\u53470.1\u70b9\u3002\u4ece\u884c\u4e1a\u770b\uff0c\u5de5\u4e1a\u548c\u793e\u4f1a\u670d\u52a1\u4e1a\u8868\u73b0\u6700\u597d\u3002\uff08\u8d22\u8054\u793e\uff09",
