                    "widgetTitle": "\u4e09\u83f1\u6c7d\u8f66\u793e\u957f\uff1a\u52a0\u5165\u672c\u7530\u65e5\u4ea7\u5408\u5e76\u78cb\u5546\u662f\u201c\u9009\u9879\u4e4b\u4e00\u201d",
                    "widgetContent": "\u4e09\u83f1\u6c7d\u8f66\u793e\u957f\u52a0\u85e4\u9686\u96c41\u670810\u65e5\u63a5\u53d7\u91c7\u8bbf\uff0c\u5173\u4e8e\u662f\u5426\u52a0\u5165\u672c\u7530\u4e0e\u65e5\u4ea7\u6c7d\u8f66\u7684\u7ecf\u8425\u5408\u5e76\u78cb\u5546\uff0c\u4ed6\u8868\u793a\u201c\u8fd9\u662f\u9009\u9879\u4e4b\u4e00\u201d\u3002\u8c08\u53ca\u8bbe\u60f3\u7684\u76ca\u5904\uff0c\u52a0\u85e4\u9686\u96c4\u79f0\u201c\u5728\uff08\u4e09\u83f1\u6c7d\u8f66\u6ca1\u6709\u751f\u4ea7\u636e\u70b9\u7684\uff09\u5317\u7f8e\u4e1a\u52a1\u65b9\u9762\u80fd\u79ef\u6781\u83b7\u5f97\u5e2e\u52a9\u201d\u3002\u52a0\u85e4\u9686\u96c4\u53e6\u5916\u6307\u51fa\uff0c\u5728\u8f66\u8f7d\u8f6f\u4ef6\u5f00\u53d1\u7b49\u65b9\u9762\uff0c\u201c\u4e5f\u4f1a\u6709\u5229\u7528\u4e24\u5bb6\u516c\u53f8\u6280\u672f\u529b\u7684\u573a\u666f\uff0c\u6709\u975e\u5e38\u5927\u7684\u76ca\u5904\u201d\u3002\u672c\u7530\u548c\u65e5\u4ea7\u53bb\u5e7412\u6708\u5ba3\u5e03\u5168\u9762\u542f\u52a8\u7ecf\u8425\u5408\u5e76\u78cb\u5546\u3002\u4e09\u83f1\u6c7d\u8f66\u6b64\u524d\u8868\u793a\uff0c\u5c06\u57281\u6708\u5e95\u524d\u540e\u5224\u65ad\u662f\u5426\u52a0\u5165\u78cb\u5546\u3002\uff08\u754c\u9762\u65b0\u95fb\uff09",
